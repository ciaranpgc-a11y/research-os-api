        "section_type": "canonical",
        "source_parser": "structured_abstract",
        "target_id": "paper-section-4-conclusions",
        "target_kind": "section",
        "target_page": null,
        "text_content": "Nearly a quarter of children with COVID-19 have gastrointestinal symptoms. It is important for clinicians to be aware of the gastrointestinal manifestation of COVID-19."
      },
