# ─── Research-OS API – Environment Variables ─────────────────────────────────
# Copy this file to `.env` and fill in the values.
# docker-compose.yml reads this file via `env_file`.
#
# Values set in docker-compose.yml `environment:` (PUB_GROBID_BASE_URL,
# DATA_LIBRARY_ROOT, PUBLICATION_FILES_ROOT) take precedence over this file.
# ──────────────────────────────────────────────────────────────────────────────

# ── OpenAI (required for AI features) ────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── OpenAlex (scholarly metadata) ────────────────────────────────────────────
OPENALEX_MAILTO=your-email@example.com
OPENALEX_API_KEY=

# ── Crossref (DOI resolution) ───────────────────────────────────────────────
CROSSREF_MAILTO=your-email@example.com

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite path inside the container; lives on the api-data volume.
DATABASE_URL=sqlite:////var/data/research_os.db

# ── CORS / Frontend ─────────────────────────────────────────────────────────
CORS_ALLOW_ORIGINS=http://localhost:5173,https://app.axiomos.studio
FRONTEND_BASE_URL=https://app.axiomos.studio
VITE_API_BASE_URL=https://api.axiomos.studio
VITE_TEST_ACCOUNT_EMAIL=
VITE_TEST_ACCOUNT_PASSWORD=

# ── Bootstrap admin (created on first start) ─────────────────────────────────
AXIOMOS_BOOTSTRAP_EMAIL=ciarang-c@hotmail.com
AXIOMOS_BOOTSTRAP_PASSWORD=change-me
AXIOMOS_BOOTSTRAP_NAME=Ciaran
AXIOMOS_BOOTSTRAP_ROLE=admin
AXIOMOS_BOOTSTRAP_EMAIL_VERIFIED=1
AXIOMOS_BOOTSTRAP_FORCE_PASSWORD=0
# Legacy compatibility if you previously keyed admin off username/email:
# ADMIN_USERNAME=
# ADMIN_EMAIL=

# ── CMR access control ──────────────────────────────────────────────────────
CMR_ADMIN_PASSWORD=changeme
